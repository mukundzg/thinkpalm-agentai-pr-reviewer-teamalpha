# Required to encrypt stored GitHub tokens and webhook secrets (Fernet key).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=

# If true (default), delete and recreate the SQLite file when schema checks fail (multi-project layout).
PREFLIGHT_AUTO_REINIT_DB=true

# Set to 1 only if you want the server to auto-create one DB project from the env vars below (legacy).
# Otherwise use the in-app onboarding wizard or Settings to add repos.
AUTO_BOOTSTRAP_ENV_PROJECT=

# Optional legacy: if set with APP_SECRET_KEY, one project is bootstrapped on first DB init.
GITHUB_TOKEN=GITHUB_TOKEN
GITHUB_WEBHOOK_SECRET=WEBHOOK_SECRET
CHROMA_PATH=./.chroma
OPENAI_API_KEY=OPENAI_API_KEY
LLM_BASE_URL=LLM_BASE_URL
LLM_MODEL=LLM_MODEL
GITHUB_REPO=GITHUB_REPO
SQLITE_DB_PATH=SQLITE_DB_PATH